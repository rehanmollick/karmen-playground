# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies -- reinstalled from package-lock.json via `npm install`
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# Test coverage reports -- generated by `npm test -- --coverage`
/coverage

# Next.js build output -- regenerated on `npm run build` or `npm run dev`
/.next/
/out/

# Production build output
/build

# OS-generated files that have no place in version control
.DS_Store

# Private keys -- should never be committed
*.pem

# Debug logs from package managers
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local environment files -- contain secrets like API URLs
.env*.local

# Vercel CLI local project config
.vercel

# TypeScript incremental build cache -- regenerated on compile
*.tsbuildinfo

# Auto-generated by Next.js on each build -- declares global types
next-env.d.ts
