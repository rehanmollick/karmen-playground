# ============================================================
# SECRETS / ENVIRONMENT FILES
# API keys, database URLs, and other secrets live here.
# .env.example is NOT ignored -- it's the safe template with
# placeholder values that shows contributors what vars are needed.
# ============================================================
.env
.env.local
.env*.local
backend/.env
frontend/.env.local

# ============================================================
# CLAUDE CODE / AI ASSISTANT CONFIG
# CLAUDE.md has project instructions for Claude Code sessions.
# .claude/ has per-user Claude Code settings and memory.
# These are local workspace tools, not part of the shipped app.
# ============================================================
CLAUDE.md
.claude/

# ============================================================
# PROJECT PLANNING / LOCAL DOCS
# docs/ and tasks/ are internal reference material and todo
# tracking used during development. They're tailored for the
# developer's Claude Code workflow, not for end users or
# contributors, so they stay local.
# ============================================================
docs/
tasks/

# ============================================================
# SCRATCH / TEMPORARY PLANNING FILES
# Ad-hoc markdown files used for brainstorming changes,
# proposals, or UI explorations. Not part of the codebase.
# ============================================================
changes*.md
ui-changes.md
proposedRiskChange.md

# ============================================================
# SPEC FILE
# The full product spec lives locally for reference but is
# too large and internal-facing to include in the repo.
# ============================================================
karmen-playground-spec-v2.md

# ============================================================
# NODE.JS / NEXT.JS
# node_modules/ is reinstalled from package-lock.json.
# .next/ and out/ are Next.js build output (regenerated on build).
# .vercel/ is Vercel CLI local project config.
# ============================================================
node_modules/
.next/
out/
.vercel/

# ============================================================
# PYTHON
# __pycache__/ and .pyc files are bytecode compiled at runtime.
# .venv/ and venv/ are local virtual environments (reinstalled
# from requirements.txt). The rest are tool-specific caches.
# ============================================================
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ============================================================
# OS-GENERATED FILES
# .DS_Store is macOS folder metadata. Thumbs.db is Windows
# thumbnail cache. Neither belongs in version control.
# ============================================================
.DS_Store
Thumbs.db

# ============================================================
# EDITOR / IDE CONFIG
# Per-user editor settings. Each developer has their own
# IDE preferences -- these shouldn't be shared via git.
# ============================================================
.idea/
.vscode/
*.swp
*~

# ============================================================
# BUILD ARTIFACTS / LOGS
# dist/ and build/ are compiled output. coverage/ is test
# coverage reports. Log files are runtime noise.
# ============================================================
dist/
build/
coverage/
*.log

# ============================================================
# TYPESCRIPT BUILD INFO
# tsconfig.tsbuildinfo is an incremental compilation cache.
# next-env.d.ts is auto-generated by Next.js on each build.
# Both are regenerated automatically and shouldn't be committed.
# ============================================================
*.tsbuildinfo
next-env.d.ts
