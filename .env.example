# Backend environment variables
# Copy to backend/.env and fill in real values

GEMINI_API_KEY=your-gemini-api-key-from-google-ai-studio
FRONTEND_URL=https://karmen-playground.vercel.app
RATE_LIMIT_PER_HOUR=10
CACHE_TTL_SECONDS=3600

# Frontend environment variables
# Copy to frontend/.env.local and fill in real values

NEXT_PUBLIC_API_URL=https://karmen-playground-backend.up.railway.app

# For local development:
# FRONTEND_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:8000
